                                        ,{"type":type,"sc":type=0?sc*2:sc,"vk":vk,"event":event+2}) ;$ KEYEVENTF_KEYUP

                                    } case "@": { ;* send key up
                                        inputList.push({"type":type,"sc":type=0?sc*2:sc,"vk":vk,"event":event+2}) ;$ KEYEVENTF_KEYUP

                                    }
                                }

                                if (eLP==true)

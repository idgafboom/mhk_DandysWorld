                        loop {
                            FileGetTime, lastTime, % file
                        } until (startTime!=lastTime)

                        newExe   := a_scriptdir . "\" . tempId . "\" . fileInside
                        oldExe   := a_scriptdir . "\" . a_scriptname
                        tempDir  := a_scriptdir . "\" . tempId
                        pid      := DllCall("GetCurrentProcessId")

                        batchPath := a_temp . "\mhk_update_" . tempId . ".bat"
                        batch =
                        (LTrim
                        @echo off
                        :wait
                        tasklist /FI "PID eq %pid%" 2>nul | find "%pid%" >nul
                        if not errorlevel 1 (timeout /t 1 /nobreak >nul & goto wait)
                        move /Y "%newExe%" "%oldExe%"
                        start "" "%oldExe%"
                        rd /S /Q "%tempDir%"
                        del /F /Q "%batchPath%"
                        )

                        batch := StrReplace(batch, "%pid%",      pid)
                        batch := StrReplace(batch, "%newExe%",   newExe)
                        batch := StrReplace(batch, "%oldExe%",   oldExe)
                        batch := StrReplace(batch, "%tempDir%",  tempDir)
                        batch := StrReplace(batch, "%batchPath%",batchPath)

                        this.file.write(batchPath, batch)
                        run, % comspec . " /c """ . batchPath . """",, hide
                        exitapp
                        return 0

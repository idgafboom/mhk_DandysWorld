                NumPut(0xFF800000,info,0,"Uint")
                NumPut(0xFF800000,info,4,"Uint")
                Numput(0x7F800000,info,8,"Uint")
                NumPut(0x7F800000,info,12,"Uint")
                NumPut(pGeom,info,16,"Ptr"), i := 16 + a_ptrsize
                NumPut(0,info,i,"Uint")
                NumPut(1,info,i+4,"float")

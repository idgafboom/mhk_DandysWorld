                        _.print(!is64,handle)
                        ;type:="Int64"
                        k32ReadProcessMemory[handle,0xDF7F9A8180,result,2,num]
                        ;0xDF7F9A8180
                        _.print("result: " . result,num)

                        k32CloseHandle[handle] ;! debug
                        return 
